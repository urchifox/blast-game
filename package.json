{
  "type": "module",
  "browserslist": [
		"last 2 versions",
		"not dead",
		"not op_mini all",
		"not and_uc > 0",
		"not < 0.2%"
	],
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.json && vite build",
    "check": "npm run lint && tsc -p tsconfig.json --noEmit",
    "prepare": "husky",
    "preview": "vite preview",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check"
  },
  "dependencies": {
    "phaser": "3.90.0"
  },
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "@types/node": "22.19.17",
    "autoprefixer": "10.4.19",
    "eslint": "9.39.4",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.5",
    "globals": "16.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.4",
    "prettier": "3.8.3",
    "typescript": "5.8.3",
    "typescript-eslint": "8.59.0",
    "vite": "6.4.2"
  },
  "lint-staged": {
    "*.{ts,js,css,html,json,md,yml,yaml}": "prettier --write"
  }
}
